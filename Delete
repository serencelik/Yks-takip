// PDF toggle state per form
const pdfState = { tyt: false, ayt: false, b: false };

function togglePdfSwitch(prefix) {
  // bs-XXX formatındaki prefix'ler pdfStateBs'e, diğerleri pdfState'e yazılır
  const isBs = prefix.startsWith('bs-');
  const key  = isBs ? prefix.slice(3) : prefix; // "bs-tyt-mat" → "tyt-mat", "tyt" → "tyt"
  if (isBs) pdfStateBs[key] = !pdfStateBs[key];
  else       pdfState[prefix] = !pdfState[prefix];
  const val = isBs ? pdfStateBs[key] : pdfState[prefix];
  const sw  = document.getElementById(prefix + '-pdf-toggle');
  const lbl = document.getElementById(prefix + '-pdf-label');
  if (!sw || !lbl) return;
  if (val) { sw.classList.add('on'); lbl.textContent = '📄 PDF'; lbl.style.color = 'var(--ayt)'; }
  else     { sw.classList.remove('on'); lbl.textContent = 'PDF değil'; lbl.style.color = 'var(--text2)'; }
}


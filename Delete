// ── Branş Liste Render (tek-ders) ─────────────────────────────
function renderBransList(tab) {
  const log = getDenemeLog().filter(d => d.type === 'brans2' && d.tab === tab);
  const listId = tab === 'ders' ? 'dList-brans' : 'bsList-' + tab;
  const list = document.getElementById(listId);
  if (!list) return;
  const color = BS_COLORS[tab] || '#8b5cf6';
  const info  = SINGLE_DERS[tab];
  const isMulti = !!MULTI_NEW_FIELDS[tab];

  if (log.length === 0) {
    list.innerHTML = `<div class="deneme-empty"><div class="deneme-empty-icon">🔬</div>Henüz deneme eklenmedi.</div>`;
    return;
  }

  // Ortalama özet kartı
  const avgNet = (log.reduce((a,d)=>a+(d.totalNet||0),0)/log.length).toFixed(2);
  let avgHtml = `<div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${color}">${avgNet}</div><div class="deneme-avg-label">Ort. Net</div></div>
    <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${color}">${log.length}</div><div class="deneme-avg-label">Deneme</div></div>`;
  if (isMulti) {
    MULTI_NEW_FIELDS[tab].forEach(({label}) => {
      const avg = (log.reduce((a,d)=>a+(d.dersNetler?.[label]?.net||0),0)/log.length).toFixed(1);
      avgHtml += `<div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${color};font-size:16px">${avg}</div><div class="deneme-avg-label" style="font-size:9px">${label}</div></div>`;
    });
  } else {
    const avgD = (log.reduce((a,d)=>a+(d.dogru||0),0)/log.length).toFixed(1);
    const avgY = (log.reduce((a,d)=>a+(d.yanlis||0),0)/log.length).toFixed(1);
    avgHtml += `<div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent3);font-size:18px">${avgD}</div><div class="deneme-avg-label">Ort. Doğru</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--danger);font-size:18px">${avgY}</div><div class="deneme-avg-label">Ort. Yanlış</div></div>`;
  }
  list.innerHTML = `<div class="deneme-avg-card" style="margin:0 0 12px"><div class="deneme-avg-grid">${avgHtml}</div></div>`;

  log.forEach(d => {
    const card = document.createElement('div');
    card.className = 'deneme-card';
    const netC = (d.totalNet||0) >= 0 ? color : 'var(--danger)';
    let scoresHtml = `<div class="deneme-score-item"><div class="deneme-score-val" style="color:${netC}">${d.totalNet??'—'}</div><div class="deneme-score-label">Net</div></div>`;
    if (isMulti && d.dersNetler) {
      Object.entries(d.dersNetler).forEach(([ders, s]) => {
        const c = (s.net||0) >= 0 ? color : 'var(--danger)';
        scoresHtml += `<div class="deneme-score-item"><div class="deneme-score-val" style="color:${c};font-size:14px">${s.net}</div><div class="deneme-score-label" style="font-size:8px">${ders}</div></div>`;
      });
    } else {
      scoresHtml += `<div class="deneme-score-item"><div class="deneme-score-val" style="color:var(--accent3)">${d.dogru??'—'}</div><div class="deneme-score-label">Doğru</div></div>
        <div class="deneme-score-item"><div class="deneme-score-val" style="color:var(--danger)">${d.yanlis??'—'}</div><div class="deneme-score-label">Yanlış</div></div>
        <div class="deneme-score-item"><div class="deneme-score-val" style="color:var(--text2)">${d.bos??'—'}</div><div class="deneme-score-label">Boş</div></div>`;
    }
    let ybSummary = '';
    if (d.konular) {
      const yy = Object.values(d.konular).filter(v=>v==='y').length;
      const bb = Object.values(d.konular).filter(v=>v==='b').length;
      if (yy>0||bb>0) ybSummary=`<div style="display:flex;gap:12px;font-size:11px;margin-top:8px;padding:6px 10px;background:var(--surface2);border-radius:10px"><span style="color:var(--danger)">✗ ${yy} yanlış</span><span style="color:var(--text2)">○ ${bb} boş</span></div>`;
    }
    const subtitle = info ? `${info.ders} (${info.cat})` : (BS_LABELS[tab]?.label || tab);
    card.innerHTML = `
      <div class="deneme-card-top">
        <div><div class="deneme-card-title">🔬 ${d.name}</div><div class="deneme-card-date">${d.date} · ${subtitle}</div></div>
        <div class="deneme-card-delete" onclick="deleteDeneme(${d.id})">🗑</div>
      </div>
      <div class="deneme-scores">${scoresHtml}</div>
      ${ybSummary}
      ${metaChips(d)}`;
    list.appendChild(card);
  });
}


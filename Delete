function saveState() {
  localStorage.setItem('yks_state', JSON.stringify(state));
}

// ========== COUNTDOWN ==========
function updateCountdown() {
  const exam = new Date(examDate);
  const now = new Date();
  const diff = Math.ceil((exam - now) / (1000 * 60 * 60 * 24));
  document.getElementById('daysLeft').textContent = diff > 0 ? diff + ' Gün' : 'Sınav Günü!';
  document.getElementById('examDateDisplay').textContent = 'YKS Tarihi: ' + exam.toLocaleDateString('tr-TR', {day:'numeric',month:'long',year:'numeric'});
}

// ========== TABS ==========
function switchTab(tab) {
  currentTab = tab;
  const tabs = document.querySelectorAll('.tab');
  tabs.forEach(t => {
    t.className = 'tab';
    if (t.textContent.trim() === tab || (tab === 'DİL' && t.textContent.trim() === 'Dil')) {
      t.className = 'tab active-' + (tab === 'TYT' ? 'tyt' : tab === 'AYT' ? 'ayt' : 'dil');
    }
  });
  renderSubjects();
}

// ========== RENDER SUBJECTS ==========
function renderSubjects() {
  const container = document.getElementById('subjectsList');
  container.innerHTML = '';
  const subjects = DATA[currentTab] || [];
  const color = currentTab === 'TYT' ? '#7c5cfc' : currentTab === 'AYT' ? '#f5a623' : '#2dde98';

  subjects.forEach((subj, si) => {
    const topics = subj.topics;
    const done = topics.filter(t => state[currentTab][subj.name][t]).length;
    const pct = Math.round((done / topics.length) * 100);

    const card = document.createElement('div');
    card.className = 'subject-card';
    card.style.animationDelay = (si * 0.05) + 's';

    const topicsHTML = topics.map(topic => {
      const isDone = state[currentTab][subj.name][topic];
      if (hideDone && isDone) return '';
      return `<div class="topic-item${isDone ? ' done' : ''}" onclick="toggleTopic('${currentTab}','${subj.name}','${topic.replace(/'/g,"\\'")}',this)">
        <div class="topic-checkbox" style="${isDone ? 'background:' + color + ';' : ''}">
          ${isDone ? '✓' : ''}
        </div>
        <div class="topic-name">${topic}</div>
      </div>`;
    }).join('');

    card.innerHTML = `
      <div class="subject-header" onclick="toggleCard(this.parentElement)">
        <div class="subject-icon" style="background:${subj.color}22">${subj.icon}</div>
        <div class="subject-info">
          <div class="subject-name">${subj.name}</div>
          <div class="subject-meta">
            <div class="subject-progress-bar">
              <div class="subject-progress-fill" style="background:${color};width:${pct}%"></div>
            </div>
            <span class="subject-pct" style="color:${color}">${pct}%</span>
          </div>
        </div>
        <div class="subject-chevron">▾</div>
      </div>
      <div class="topics-list">${topicsHTML}</div>
    `;

    container.appendChild(card);
  });
}

function toggleCard(card) {
  card.classList.toggle('expanded');
}

// ========== TOGGLE TOPIC ==========
function toggleTopic(cat, subj, topic, el) {
  const current = state[cat][subj][topic];
  state[cat][subj][topic] = !current;
  saveState();

  el.classList.toggle('done');
  const cb = el.querySelector('.topic-checkbox');
  const color = cat === 'TYT' ? '#7c5cfc' : cat === 'AYT' ? '#f5a623' : '#2dde98';
  if (!current) {
    cb.style.background = color;
    cb.style.borderColor = 'transparent';
    cb.textContent = '✓';
    showToast('✅ Konu tamamlandı!');
  } else {
    cb.style.background = '';
    cb.style.borderColor = '';
    cb.textContent = '';
  }

  updateOverview();
  updateSubjectProgress(cat, subj);
}

function updateSubjectProgress(cat, subj) {
  // Update the specific card's progress bar without full re-render
  const subjects = DATA[cat];
  const si = subjects.findIndex(s => s.name === subj);
  if (si < 0) return;
  const topics = subjects[si].topics;
  const done = topics.filter(t => state[cat][subj][t]).length;
  const pct = Math.round((done / topics.length) * 100);
  const color = cat === 'TYT' ? '#7c5cfc' : cat === 'AYT' ? '#f5a623' : '#2dde98';

  const cards = document.querySelectorAll('#subjectsList .subject-card');
  if (cards[si]) {
    const bar = cards[si].querySelector('.subject-progress-fill');
    const pctEl = cards[si].querySelector('.subject-pct');
    if (bar) bar.style.width = pct + '%';
    if (pctEl) pctEl.textContent = pct + '%';
  }
}

// ========== OVERVIEW ==========
function updateOverview() {
  for (const cat of ['TYT', 'AYT']) {
    const subjects = DATA[cat];
    let total = 0, done = 0;
    for (const subj of subjects) {
      for (const topic of subj.topics) {
        total++;
        if (state[cat][subj.name][topic]) done++;
      }
    }
    const pct = total ? Math.round((done / total) * 100) : 0;
    const key = cat === 'DİL' ? 'dil' : cat.toLowerCase();
    document.getElementById(key + '-pct').textContent = pct + '%';
    document.getElementById(key + '-bar').style.width = pct + '%';
  }
}

// ========== STATS ==========
function renderStats() {
  let totalDone = 0, totalTopics = 0;
  for (const [cat, subjects] of Object.entries(DATA)) {
    for (const subj of subjects) {
      for (const topic of subj.topics) {
        totalTopics++;
        if (state[cat][subj.name][topic]) totalDone++;
      }
    }
  }

  document.getElementById('totalDone').textContent = totalDone;
  document.getElementById('totalPct').textContent = '%' + (totalTopics ? Math.round((totalDone/totalTopics)*100) : 0);

  // Çalışma istatistikleri
  const log = getWorkLog();
  const days = Object.keys(log);
  const totalSecs = Object.values(log).reduce((a,b) => a+b, 0);
  const avgSecs = days.length > 0 ? Math.round(totalSecs / days.length) : 0;
  document.getElementById('statTotalHours').textContent = formatHours(totalSecs);
  document.getElementById('statAvgHours').textContent = formatHours(avgSecs);

  // Isı haritası — 10 Mart'tan sınava kadar sabit, 13 sütun
  const heatmap = document.getElementById('heatmap');
  heatmap.innerHTML = '';
  const today = new Date();
  today.setHours(0,0,0,0);
  const exam = new Date(examDate);
  exam.setHours(0,0,0,0);

  const startDate = new Date('2026-03-11');
  startDate.setHours(0,0,0,0);
  const totalDays = Math.ceil((exam - startDate) / (1000*60*60*24)) + 2; // +2: TYT(20) + AYT(21)


  const examTYT = new Date('2026-06-20'); examTYT.setHours(0,0,0,0);
  const examAYT = new Date('2026-06-21'); examAYT.setHours(0,0,0,0);

  for (let i = 0; i < totalDays; i++) {
    const d = new Date(startDate);
    d.setDate(startDate.getDate() + i);
    const key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
    const secs = log[key] || 0;
    const hours = secs / 3600;
    const isFuture = d > today;
    const isToday = d.getTime() === today.getTime();
    const isTYT = d.getTime() === examTYT.getTime();
    const isAYT = d.getTime() === examAYT.getTime();
    const isExam = isTYT || isAYT;

    let bg;
    if (isTYT) bg = '#ff4d6a';
    else if (isAYT) bg = '#fb923c';
    else if (isFuture) bg = 'rgba(255,255,255,0.05)';
    else if (hours === 0) bg = '#0d1117';
    else if (hours < 2) bg = '#0d2a4a';
    else if (hours < 4) bg = '#0e4d8f';
    else if (hours < 6) bg = '#1a7fd4';
    else bg = '#60b8ff';

    const cell = document.createElement('div');
    cell.className = 'hm-cell' + (isToday ? ' today' : '');
    cell.style.background = bg;
    cell.style.opacity = isFuture && !isExam ? '0.35' : '1';
    cell.dataset.key = key;
    cell.dataset.secs = secs;
    cell.dataset.exam = isTYT ? 'tyt' : isAYT ? 'ayt' : '0';
    cell.dataset.future = isFuture ? '1' : '0';
    cell.dataset.label = d.toLocaleDateString('tr-TR', {weekday:'long', day:'numeric', month:'long', year:'numeric'});

    cell.addEventListener('click', e => showHmPopup(e, cell));
    heatmap.appendChild(cell);
  }

  // Geçmiş liste — element varsa güncelle (kaldırılmış olabilir)
  const histList = document.getElementById('historyList');
  if (histList) {
    histList.innerHTML = '';
    const sortedDays = Object.entries(log).sort((a,b) => b[0].localeCompare(a[0]));
    if (sortedDays.length === 0) {
      histList.innerHTML = '<div style="text-align:center;color:var(--text2);font-size:13px;padding:20px 0">Henüz çalışma kaydı yok 📝</div>';
    } else {
      sortedDays.forEach(([dateKey, secs]) => {
        const d = new Date(dateKey);
        const label = d.toLocaleDateString('tr-TR', {day:'numeric', month:'long', weekday:'short'});
        histList.innerHTML += `<div class="history-item">
          <div class="history-item-date">${label}</div>
          <div class="history-item-hours">${formatHours(secs)}</div>
        </div>`;
      });
    }
  }
  // Ders bazında
  const breakdown = document.getElementById('subjectBreakdown');
  breakdown.innerHTML = '';
  for (const [cat, subjects] of Object.entries(DATA)) {
    const color = cat === 'TYT' ? '#7c5cfc' : '#f5a623';
    for (const subj of subjects) {
      const total = subj.topics.length;
      const done = subj.topics.filter(t => state[cat][subj.name][t]).length;
      const pct = Math.round((done/total)*100);
      breakdown.innerHTML += `
        <div class="settings-item" style="margin-bottom:8px">
          <span style="font-size:13px">${subj.icon} ${subj.name}</span>
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:80px;height:4px;background:rgba(255,255,255,0.07);border-radius:100px;overflow:hidden">
              <div style="height:100%;width:${pct}%;background:${color};border-radius:100px"></div>
            </div>

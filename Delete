<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>YKS Takip</title>

<style>
  :root {
    --bg: #0a0a0f;
    --surface: #12121a;
    --surface2: #1a1a28;
    --border: rgba(255,255,255,0.07);
    --accent: #7c5cfc;
    --accent2: #f5a623;
    --accent3: #2dde98;
    --text: #e8e8f0;
    --text2: #7878a0;
    --danger: #ff4d6a;
    --tyt: #7c5cfc;
    --ayt: #f5a623;
    --dil: #2dde98;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
    min-height: 100vh;
    max-width: 430px;
    margin: 0 auto;
    overflow-x: hidden;
  }

  /* Grain overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* HEADER */
  .header {
    padding: 52px 24px 24px;
    position: relative;
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(124,92,252,0.15);
    border: 1px solid rgba(124,92,252,0.3);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .header h1 {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 32px;
    font-weight: 800;
    line-height: 1.1;
    color: var(--text);
  }

  .header h1 span {
    background: linear-gradient(135deg, var(--accent), #b388ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .header h1 span.white {
    background: none;
    -webkit-background-clip: unset;
    -webkit-text-fill-color: #ffffff;
    background-clip: unset;
    color: #ffffff;
  }

  .header-sub {
    font-size: 14px;
    color: var(--text2);
    margin-top: 6px;
  }

  /* COUNTDOWN */
  .countdown-card {
    margin: 0 24px 24px;
    background: linear-gradient(135deg, rgba(124,92,252,0.2), rgba(124,92,252,0.05));
    border: 1px solid rgba(124,92,252,0.25);
    border-radius: 20px;
    padding: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .countdown-icon {
    font-size: 32px;
    line-height: 1;
  }

  .countdown-info { flex: 1; }
  .countdown-label { font-size: 11px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
  .countdown-days {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }
  .countdown-date { font-size: 12px; color: var(--text2); margin-top: 2px; }

  /* GENEL İLERLEME */
  .section {
    padding: 0 24px;
    margin-bottom: 28px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .section-title {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }

  .section-link {
    font-size: 13px;
    color: var(--accent);
    cursor: pointer;
    user-select: none;
  }

  /* OVERVIEW CARDS */
  .overview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .overview-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 14px 12px;
    text-align: center;
    transition: transform 0.2s;
  }

  .overview-card:active { transform: scale(0.97); }

  .overview-card .ov-pct {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 2px;
  }

  .overview-card .ov-label {
    font-size: 10px;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ov-tyt .ov-pct { color: var(--tyt); }
  .ov-ayt .ov-pct { color: var(--ayt); }
  .ov-dil .ov-pct { color: var(--dil); }

  .ov-bar {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.07);
    border-radius: 100px;
    margin-top: 8px;
    overflow: hidden;
  }

  .ov-bar-fill {
    height: 100%;
    border-radius: 100px;
    transition: width 1s ease;
  }

  /* TABS */
  .tabs {
    display: flex;
    gap: 8px;
    padding: 0 24px;
    margin-bottom: 16px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs::-webkit-scrollbar { display: none; }

  .tab {
    flex-shrink: 0;
    padding: 8px 18px;
    border-radius: 100px;
    border: 1px solid var(--border);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
    background: var(--surface);
    color: var(--text2);
  }

  .tab.active-tyt { background: rgba(124,92,252,0.2); border-color: var(--tyt); color: var(--tyt); }
  .tab.active-ayt { background: rgba(245,166,35,0.2); border-color: var(--ayt); color: var(--ayt); }
  .tab.active-dil { background: rgba(45,222,152,0.2); border-color: var(--dil); color: var(--dil); }

  /* SUBJECT CARDS */
  .subjects-list {
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .subject-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    transition: transform 0.2s;
  }

  .subject-card:active { transform: scale(0.99); }

  .subject-header {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px;
    cursor: pointer;
  }

  .subject-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }

  .subject-info { flex: 1; min-width: 0; }

  .subject-name {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .subject-meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .subject-progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.07);
    border-radius: 100px;
    overflow: hidden;
  }

  .subject-progress-fill {
    height: 100%;
    border-radius: 100px;
    transition: width 0.8s ease;
  }

  .subject-pct {
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .subject-chevron {
    font-size: 16px;
    color: var(--text2);
    transition: transform 0.3s;
    flex-shrink: 0;
  }

  .subject-card.expanded .subject-chevron {
    transform: rotate(180deg);
  }

  /* TOPICS */
  .topics-list {
    display: none;
    padding: 0 16px 16px;
    flex-direction: column;
    gap: 6px;
  }

  .subject-card.expanded .topics-list {
    display: flex;
  }

  .topic-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    background: var(--surface2);
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.2s;
    user-select: none;
  }

  .topic-item:active { background: rgba(255,255,255,0.05); }

  .topic-checkbox {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    border: 2px solid rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    font-size: 13px;
  }

  .topic-item.done .topic-checkbox {
    border-color: transparent;
    color: white;
  }

  .topic-name {
    flex: 1;
    font-size: 13px;
    transition: all 0.2s;
  }

  .topic-item.done .topic-name {
    color: var(--text2);
    text-decoration: line-through;
  }

  .topic-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 100px;
    font-weight: 500;
    flex-shrink: 0;
  }

  /* BOTTOM NAV */
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 430px;
    background: rgba(10,10,15,0.9);
    backdrop-filter: blur(20px);
    border-top: 1px solid var(--border);
    display: flex;
    padding: 12px 0 28px;
    z-index: 100;
  }

  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    padding: 4px 0;
    user-select: none;
    color: var(--text2);
    transition: color 0.2s;
  }

  .nav-item.active { color: var(--accent); }
  .nav-icon { font-size: 22px; }
  .nav-label { font-size: 10px; font-weight: 500; }

  /* STUDY LOG MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 200;
    backdrop-filter: blur(4px);
    align-items: flex-end;
    justify-content: center;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border-radius: 28px 28px 0 0;
    padding: 24px 24px 48px;
    width: 100%;
    max-width: 430px;
    border: 1px solid var(--border);
    border-bottom: none;
    animation: slideUp 0.3s ease;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .modal-handle {
    width: 40px;
    height: 4px;
    background: rgba(255,255,255,0.15);
    border-radius: 100px;
    margin: 0 auto 20px;
  }

  .modal-title {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 20px;
  }

  .log-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 20px;
  }

  .log-stat {
    background: var(--surface2);
    border-radius: 16px;
    padding: 16px;
  }

  .log-stat-val {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 4px;
  }

  .log-stat-label { font-size: 12px; color: var(--text2); }

  .log-week {
    display: flex;
    gap: 6px;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .log-day {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .log-day-bar-wrap {
    width: 100%;
    height: 60px;
    background: var(--surface2);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .log-day-bar {
    width: 100%;
    border-radius: 8px;
    transition: height 0.6s ease;
  }

  .log-day-label { font-size: 10px; color: var(--text2); }

  .close-btn {
    width: 100%;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 14px;
    padding: 16px;
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
  }

  /* SCROLLPAD for bottom nav */
  .scroll-pad { height: 100px; }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: rgba(30,30,45,0.95);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 20px;
    font-size: 13px;
    font-weight: 500;
    opacity: 0;
    transition: all 0.3s;
    pointer-events: none;
    white-space: nowrap;
    z-index: 300;
    backdrop-filter: blur(10px);
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* SEARCH / Settings page */
  .page { display: none; }
  .page.active { display: block; }

  .settings-section {
    padding: 0 24px;
    margin-bottom: 20px;
  }

  .settings-title {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 10px;
  }

  .settings-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 8px;
  }

  .settings-item-label { font-size: 14px; }
  .settings-item-val { font-size: 14px; color: var(--accent); font-weight: 600; }

  .toggle {
    width: 44px;
    height: 26px;
    background: var(--surface2);
    border-radius: 100px;
    position: relative;
    cursor: pointer;
    border: 1px solid var(--border);
    transition: background 0.2s;
  }

  .toggle.on { background: var(--accent); border-color: var(--accent); }

  .toggle::after {
    content: '';
    position: absolute;
    left: 3px;
    top: 3px;
    width: 18px;
    height: 18px;
    background: white;
    border-radius: 100%;
    transition: left 0.2s;
  }

  .toggle.on::after { left: 21px; }

  .exam-date-input {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 8px 12px;
    color: var(--text);
    font-family: 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
    font-size: 14px;
    outline: none;
    width: 160px;
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .subject-card { animation: fadeIn 0.3s ease both; }

  /* SAYAÇ */
  .timer-card {
    margin: 0 24px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 20px;
  }
  .timer-display {
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 38px;
    font-weight: 800;
    text-align: center;
    letter-spacing: 0.04em;
    color: var(--text);
    line-height: 1;
    margin: 8px 0 16px;
  }
  .timer-display.running { color: var(--accent3); }
  .timer-label {
    font-size: 11px;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
    margin-bottom: 4px;
  }
  .timer-buttons { display: flex; gap: 10px; justify-content: center; }
  .timer-btn {
    flex: 1;
    padding: 14px;
    border-radius: 14px;
    border: none;
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  .timer-btn:active { transform: scale(0.97); }
  .timer-btn-start { background: var(--accent3); color: #0a0a0f; }
  .timer-btn-pause { background: var(--accent2); color: #0a0a0f; }
  .timer-btn-stop  { background: rgba(255,255,255,0.07); color: var(--text2); border: 1px solid var(--border); }
  .timer-today { text-align: center; font-size: 13px; color: var(--text2); margin-top: 14px; }
  .timer-today span { color: var(--accent3); font-weight: 700; }

  /* GEÇMİŞ ÇALIŞMA */
  .history-heatmap {
    display: grid;
    grid-template-columns: repeat(13, 1fr);
    gap: 4px;
    margin-bottom: 6px;
  }
  .hm-cell {
    aspect-ratio: 1;
    border-radius: 5px;
    background: var(--surface2);
    position: relative;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .hm-cell:hover { transform: scale(1.15); box-shadow: 0 0 0 2px rgba(255,255,255,.25); }
  .hm-cell.today { outline: 2px solid var(--accent); outline-offset: 1px; }
  /* Gün detay popup */
  #hmPopup {
    position: fixed; z-index: 9990;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 14px 16px;
    min-width: 180px;
    box-shadow: 0 8px 32px rgba(0,0,0,.5);
    pointer-events: none;
    opacity: 0;
    transition: opacity .15s;
  }
  #hmPopup.visible { opacity: 1; pointer-events: auto; }
  .history-legend {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: flex-end;
    font-size: 10px;
    color: var(--text2);
    margin-top: 4px;
  }
  .legend-cell { width: 12px; height: 12px; border-radius: 3px; }
  .history-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: 220px;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .history-list::-webkit-scrollbar { display: none; }
  .history-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--surface2);
    border-radius: 12px;
    padding: 10px 14px;
  }
  .history-item-date { font-size: 13px; color: var(--text2); }
  .history-item-hours { font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif; font-size: 15px; font-weight: 700; color: var(--accent3); }

  /* DENEME SAYFASI */
  .deneme-tabs { display: flex; gap: 8px; padding: 0 24px; margin-bottom: 20px; }
  .deneme-tab {
    flex: 1; padding: 12px; border-radius: 14px; border: 1px solid var(--border);
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif; font-size: 13px; font-weight: 700;
    text-align: center; cursor: pointer; background: var(--surface); color: var(--text2); transition: all 0.2s;
  }
  .deneme-tab.active-genel { background: rgba(124,92,252,0.2); border-color: var(--accent); color: var(--accent); }
  .deneme-tab.active-brans { background: rgba(245,166,35,0.2); border-color: var(--accent2); color: var(--accent2); }
  .deneme-form { padding: 0 24px; display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
  .deneme-form-row { display: flex; gap: 10px; }
  .deneme-input-group { flex: 1; display: flex; flex-direction: column; gap: 6px; }
  .deneme-input-label { font-size: 11px; color: var(--text2); text-transform: uppercase; letter-spacing: 0.06em; }
  .deneme-input {
    background: var(--surface2); border: 1px solid var(--border); border-radius: 12px;
    padding: 12px 14px; color: var(--text); font-family: 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
    font-size: 14px; outline: none; width: 100%; transition: border-color 0.2s;
  }
  .deneme-input:focus { border-color: var(--accent); }
  .deneme-select {
    background: var(--surface2); border: 1px solid var(--border); border-radius: 12px;
    padding: 12px 14px; color: var(--text); font-family: 'SF Pro Text', 'Segoe UI', system-ui, sans-serif;
    font-size: 14px; outline: none; width: 100%; appearance: none; cursor: pointer;
  }
  .deneme-add-btn {
    background: var(--accent); color: white; border: none; border-radius: 14px; padding: 14px;
    font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif; font-size: 15px; font-weight: 700; cursor: pointer; width: 100%;
  }
  .deneme-add-btn:active { opacity: 0.8; }
  .deneme-list { padding: 0 24px; display: flex; flex-direction: column; gap: 10px; }
  .deneme-card { background: var(--surface); border: 1px solid var(--border); border-radius: 18px; padding: 16px; animation: fadeIn 0.3s ease; }
  .deneme-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .deneme-card-title { font-family: 'SF Pro Display', 'Segoe UI', system-ui, sans-serif; font-size: 15px; font-weight: 700; }
  .deneme-card-date { font-size: 11px; color: var(--text2); margin-top: 2px; }
  .deneme-card-delete { font-size: 16px; cursor: pointer; color: var(--text2); padding: 2px 6px; border-radius: 8px; transition: color 0.2s; }
  .deneme-card-delete:active { color: var(--danger); }
  .deneme-scores { display: grid; grid-template-columns: repeat(auto-fill, minmax(58px, 1fr)); gap: 6px; margin-bottom: 10px; }
  .deneme-score-item { background: var(--surface2); border-radius: 10px; padding: 8px 10px; text-align: center; }

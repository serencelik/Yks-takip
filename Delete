function addYayinevi(pfx) {
  const input = document.getElementById('yayinevi-new-input');
  const val = input?.value.trim();
  if (!val) return;
  const list = getYayinevleri();
  if (list.includes(val)) { showToast('⚠️ Bu yayınevi zaten var'); return; }
  list.push(val);
  saveYayinevleri(list);
  refreshYayineviSelects();
  selectYayineviFromModal(pfx, val);
}

function deleteYayinevi(name) {
  const list = getYayinevleri().filter(y => y !== name);
  saveYayinevleri(list);
  refreshYayineviSelects();
  // Modalı yenile
  const modal = document.getElementById('yayinevi-modal');
  if (modal) {
    const pfxMatch = modal.innerHTML.match(/addYayinevi\('([^']+)'\)/);
    const pfx = pfxMatch ? pfxMatch[1] : '';
    document.getElementById('yayinevi-modal').remove();
    openYayineviModal(pfx);
  }
}

function selectYayineviFromModal(pfx, name) {
  const sel = document.getElementById(pfx + '-yayinevi');
  if (sel) sel.value = name;
  document.getElementById('yayinevi-modal')?.remove();
  refreshYayineviSelects();
  // Seçili değeri tekrar set et (refresh sonrası)
  const sel2 = document.getElementById(pfx + '-yayinevi');
  if (sel2) sel2.value = name;
  showToast(`✅ "${name}" seçildi`);
}


  const container = document.getElementById('istatContent');
  const yerEmoji = {ev:'🏠 Ev', dershane:'🏫 Dershane', kutuphane:'📚 Kütüphane'};
  const yerKeys = ['ev','dershane','kutuphane'];

  // Chip stillerini güncelle
  const chipColors = {
    'tyt-turkce':'#a78bfa','tyt-problem':'#818cf8','tyt-mat':'#60a5fa','tyt-geo':'#93c5fd',
    'tyt-mat-prob':'#7dd3fc','tyt-fen-den':'#f472b6','tyt-fiz':'#f472b6','tyt-kim':'#e879a0',
    'tyt-bio':'#34d399','tyt-sos-den':'#fbbf24','tyt-tar':'#fbbf24','tyt-cog':'#fb923c',
    'tyt-fel':'#e879a0','tyt-din':'#f472b6','ayt-mat':'#fb923c','ayt-geo':'#fdba74',
    'ayt-fen-den':'#c084fc','ayt-fiz':'#c084fc','ayt-kim':'#a78bfa','ayt-bio':'#6ee7b7'
  };
  Object.entries(chipColors).forEach(([tab, color]) => {
    const chip = document.getElementById('istchip-' + tab);
    if (!chip) return;
    if (tab === istatBransDers) {
      chip.style.borderColor = color; chip.style.background = color+'22'; chip.style.color = color;
    } else {
      chip.style.borderColor = ''; chip.style.background = ''; chip.style.color = '';
    }
  });

  let html = `<div style="background:var(--surface2);border-radius:16px;padding:12px 14px;margin-bottom:16px">
    <div style="font-size:10px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">🔽 Filtrele</div>
    <div style="font-size:11px;color:var(--text2);margin-bottom:6px">Yer</div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px">`;
  yerKeys.forEach(y => {
    const seç = istatFiltreler.yer.includes(y);
    html += `<div onclick="toggleIstatYer('${y}')" style="padding:5px 11px;border-radius:20px;font-size:11px;cursor:pointer;font-weight:600;border:1.5px solid ${seç?'var(--accent3)':'var(--border)'};background:${seç?'rgba(45,222,152,.15)':'transparent'};color:${seç?'var(--accent3)':'var(--text2)'}">${yerEmoji[y]}</div>`;
  });
  const pdfOnSel = istatFiltreler.pdf === true;
  const pdfOffSel = istatFiltreler.pdf === false;
  const aktifFiltre = istatFiltreler.yer.length > 0 || istatFiltreler.pdf !== null;
  html += `</div><div style="font-size:11px;color:var(--text2);margin-bottom:6px">Format</div>
    <div style="display:flex;gap:6px;flex-wrap:wrap">
      <div onclick="toggleIstatPdf(true)" style="padding:5px 11px;border-radius:20px;font-size:11px;cursor:pointer;font-weight:600;border:1.5px solid ${pdfOnSel?'var(--ayt)':'var(--border)'};background:${pdfOnSel?'rgba(245,166,35,.15)':'transparent'};color:${pdfOnSel?'var(--ayt)':'var(--text2)'}">📄 PDF</div>
      <div onclick="toggleIstatPdf(false)" style="padding:5px 11px;border-radius:20px;font-size:11px;cursor:pointer;font-weight:600;border:1.5px solid ${pdfOffSel?'var(--text)':'var(--border)'};background:${pdfOffSel?'rgba(255,255,255,.08)':'transparent'};color:${pdfOffSel?'var(--text)':'var(--text2)'}">📚 Kitap/Yazılı</div>
      ${aktifFiltre ? `<div onclick="istatFiltreler={yer:[],pdf:null};renderIstatistik()" style="padding:5px 11px;border-radius:20px;font-size:11px;cursor:pointer;border:1.5px solid var(--danger);color:var(--danger)">✕ Temizle</div>` : ''}
    </div>
  </div>`;

  const log = applyIstatFiltre(tumLog);

  if (log.length === 0) {
    html += `<div class="deneme-empty" style="padding:40px 20px"><div class="deneme-empty-icon">📊</div>${aktifFiltre||istatBransDers ? 'Bu filtreye uyan deneme bulunamadı.' : 'Henüz deneme eklenmedi.'}</div>`;
    container.innerHTML = html;
    return;
  }

  // ── Özet kartları ─────────────────────────────────────────
  const selLabel = istatBransDers ? (BS_LABELS[istatBransDers]?.label || istatBransDers) : 'Tümü';
  const selColor = istatBransDers ? (BS_LABELS[istatBransDers]?.color || '#8b5cf6') : '#7c5cfc';
  const avgTotal = log.length ? (log.reduce((a,d)=>a+(d.totalNet||d.net||0),0)/log.length).toFixed(2) : '—';
  const tytLog = log.filter(d=>d.type==='tyt');
  const aytLog = log.filter(d=>d.type==='ayt');
  const bransLog = log.filter(d=>d.type==='brans'||d.type==='brans2');
  const avg = arr => arr.length ? (arr.reduce((a,d)=>a+(d.totalNet||0),0)/arr.length).toFixed(1) : '—';

  if (!istatBransDers) {
    html += `<div class="deneme-avg-grid" style="margin-bottom:16px">
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent)">${tytLog.length}</div><div class="deneme-avg-label">TYT</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--ayt)">${aytLog.length}</div><div class="deneme-avg-label">AYT</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent);font-size:18px">${avg(tytLog)}</div><div class="deneme-avg-label">Ort. TYT Net</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--ayt);font-size:18px">${avg(aytLog)}</div><div class="deneme-avg-label">Ort. AYT Net</div></div>
    </div>`;
  } else {
    html += `<div style="font-size:11px;color:var(--text2);margin-bottom:8px;font-weight:600">${selLabel} Özeti</div>`;
    html += `<div class="deneme-avg-grid" style="margin-bottom:12px">
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${selColor}">${log.length}</div><div class="deneme-avg-label">Deneme</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${selColor};font-size:18px">${avgTotal}</div><div class="deneme-avg-label">Ort. Net</div></div>
    </div>`;
    // Seçili bir tab varsa ders bazında ort. netler
    if (istatBransDers && MULTI_FIELDS[istatBransDers]) {
      const fields = MULTI_FIELDS[istatBransDers];
      let dersAvgHtml = '';
      fields.forEach(([,ders]) => {
        const dersLogs = log.filter(d=>d.dersNetler?.[ders]);
        if (dersLogs.length === 0) return;
        const dAvg = (dersLogs.reduce((a,d)=>a+(d.dersNetler[ders].net||0),0)/dersLogs.length).toFixed(2);
        const dAvgD = (dersLogs.reduce((a,d)=>a+(d.dersNetler[ders].dogru||0),0)/dersLogs.length).toFixed(1);
        const dAvgY = (dersLogs.reduce((a,d)=>a+(d.dersNetler[ders].yanlis||0),0)/dersLogs.length).toFixed(1);
        dersAvgHtml += `<div style="background:var(--surface2);border-radius:12px;padding:10px 14px;margin-bottom:8px">
          <div style="font-size:12px;font-weight:700;color:${selColor};margin-bottom:8px">${ders}</div>
          <div class="deneme-avg-grid">
            <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${selColor};font-size:16px">${dAvg}</div><div class="deneme-avg-label">Ort. Net</div></div>
            <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent3);font-size:16px">${dAvgD}</div><div class="deneme-avg-label">Ort. Doğru</div></div>
            <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--danger);font-size:16px">${dAvgY}</div><div class="deneme-avg-label">Ort. Yanlış</div></div>
          </div>
        </div>`;
      });
      if (dersAvgHtml) html += `<div class="istat-section" style="margin-bottom:4px"><div class="section-title" style="margin-bottom:10px">📊 Ders Bazında Ortalama</div>${dersAvgHtml}</div>`;
      // Deneme bazında net gelişimi (son 8)
      const son8 = [...log].reverse().slice(0, 8);
      if (son8.length > 1) {
        const maxN = Math.max(...son8.map(d=>d.totalNet||0));
        html += `<div class="istat-section"><div class="section-title" style="margin-bottom:10px">📈 Gelişim (Son ${son8.length})</div>`;
        son8.forEach(d => {
          const pct = maxN > 0 ? Math.round(((d.totalNet||0)/maxN)*100) : 0;
          html += `<div class="istat-konu-item" style="margin-bottom:5px">
            <div class="istat-konu-name" style="font-size:11px">${d.name} <span style="color:var(--text2);font-size:9px">${d.date}</span></div>
            <span style="font-size:11px;font-weight:700;color:${selColor};margin-right:6px;flex-shrink:0">${d.totalNet||0}</span>
            <div class="istat-bar-wrap"><div class="istat-bar-fill" style="width:${pct}%;background:${selColor}"></div></div>
          </div>`;
        });
        html += `</div>`;
      }
    }
  }

  // ── Konu yanlışları (deneme bazında) ─────────────────────
  html += `<div class="istat-section">
    <div class="section-title" style="margin-bottom:4px">📌 Konu Yanlışları</div>
    <div style="font-size:11px;color:var(--text2);margin-bottom:12px">Deneme başlığına tıkla → detay</div>`;
  const konuLog = log.filter(d=>d.konular && Object.values(d.konular).some(v=>v));
  if (konuLog.length === 0) {
    html += `<div style="font-size:13px;color:var(--text2);padding:6px 0">İşaretlenmiş yanlış/boş konu yok.</div>`;
  } else {
    konuLog.forEach((d, di) => {
      const yy = Object.values(d.konular).filter(v=>v==='y').length;
      const bb = Object.values(d.konular).filter(v=>v==='b').length;
      if (yy === 0 && bb === 0) return;
      const did = 'dkonu_'+di;
      const icon = '';
      html += `<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border)">
        <div onclick="toggleIstatDers('${did}')" style="flex:1;cursor:pointer;user-select:none">
          <div style="font-size:13px;font-weight:700">${icon} ${d.name}</div>
          <div style="font-size:10px;color:var(--text2)">${d.date}${d.tab?' · '+(BS_LABELS[d.tab]?.label||d.tab):''}</div>
        </div>
        <div style="display:flex;align-items:center;gap:8px">
          ${yy>0?`<span style="font-size:11px;color:var(--danger);font-weight:700">✗${yy}</span>`:''}
          ${bb>0?`<span style="font-size:11px;color:var(--text2)">○${bb}</span>`:''}
          <span onclick="event.stopPropagation();deleteIstatDeneme(${d.id})" style="font-size:15px;cursor:pointer;padding:2px 6px;border-radius:8px;color:var(--danger)">🗑</span>
          <span onclick="toggleIstatDers('${did}')" id="${did}-ch" style="font-size:13px;color:var(--text2);transition:transform .2s;cursor:pointer">▾</span>
        </div>
      </div>
      <div id="${did}" style="display:none;padding:6px 0 4px">`;
      const dersMap = {};
      Object.entries(d.konular).forEach(([key,val]) => {
        if (!val) return;
        const [ders,konu] = key.split('|');
        if (!dersMap[ders]) dersMap[ders] = [];
        dersMap[ders].push({konu,val});
      });
      Object.entries(dersMap).forEach(([ders,konular]) => {
        html += `<div style="font-size:11px;font-weight:700;color:var(--text2);padding:4px 0 2px">${ders}</div>`;
        konular.forEach(({konu,val}) => {
          html += `<div style="display:flex;align-items:center;gap:8px;padding:5px 10px;margin:2px 0;background:var(--surface2);border-radius:10px">
            <div style="flex:1;font-size:12px">${konu}</div>
            ${val==='y'?`<span style="font-size:10px;background:rgba(255,77,106,.18);color:var(--danger);padding:2px 7px;border-radius:20px;font-weight:700">✗</span>`:`<span style="font-size:10px;background:rgba(255,255,255,.07);color:var(--text2);padding:2px 7px;border-radius:20px">○</span>`}
          </div>`;
        });
      });
      html += `</div>`;
    });
  }
  html += `</div>`;

  // ── Yer ──────────────────────────────────────────────────
  const yerS={ev:0,dershane:0,kutuphane:0}, yerN={ev:[],dershane:[],kutuphane:[]};
  log.forEach(d => {
    const y=d.yer||'ev'; if(yerS[y]!==undefined){ yerS[y]++; const n=d.totalNet??d.net; if(n!=null)yerN[y].push(n); }
  });
  const yTot = Object.values(yerS).reduce((a,b)=>a+b,0);
  html += `<div class="istat-section"><div class="section-title" style="margin-bottom:12px">📍 Yer</div>`;
  yerKeys.forEach(y => {
    const cnt=yerS[y]; if(!cnt) return;
    const pct=Math.round((cnt/yTot)*100);
    const avg=yerN[y].length?(yerN[y].reduce((a,b)=>a+b,0)/yerN[y].length).toFixed(1):'—';
    html += `<div class="istat-konu-item"><div class="istat-konu-name" style="font-weight:600">${yerEmoji[y]}</div>
      <span style="font-size:11px;color:var(--accent);margin-right:6px;font-weight:700">${cnt}</span>
      <span style="font-size:11px;color:var(--text2);margin-right:6px">∅${avg}</span>
      <div class="istat-bar-wrap" style="width:55px"><div class="istat-bar-fill" style="width:${pct}%;background:var(--accent)"></div></div>
      <div class="istat-konu-pct" style="color:var(--accent)">%${pct}</div></div>`;
  });
  html += `</div>`;

  // ── Süre ─────────────────────────────────────────────────
  const sureli=log.filter(d=>d.sure);
  if(sureli.length>0){
    const topS=sureli.reduce((a,d)=>a+d.sure,0);
    const maxD=sureli.reduce((a,b)=>b.sure>a.sure?b:a);
    html += `<div class="istat-section"><div class="section-title" style="margin-bottom:12px">⏱ Süre</div>
      <div class="deneme-avg-grid" style="margin-bottom:10px">
        <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent)">${Math.round(topS/sureli.length)}<span style="font-size:11px">dk</span></div><div class="deneme-avg-label">Ortalama</div></div>
        <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent3)">${topS}<span style="font-size:11px">dk</span></div><div class="deneme-avg-label">Toplam</div></div>
      </div>`;
    sureli.sort((a,b)=>b.sure-a.sure).forEach(d=>{
      const pct=Math.round((d.sure/maxD.sure)*100);
      html+=`<div class="istat-konu-item"><div class="istat-konu-name">${''} ${d.name} <span style="color:var(--text2);font-size:10px">${d.date}</span></div>
        <span style="font-size:11px;color:var(--accent3);font-weight:700;margin-right:6px">${d.sure}dk</span>
        <div class="istat-bar-wrap"><div class="istat-bar-fill" style="width:${pct}%;background:var(--accent3)"></div></div></div>`;
    });
    html += `</div>`;
  }

  // ── PDF ───────────────────────────────────────────────────
  const pdfli=log.filter(d=>d.pdf), pdfSiz=log.filter(d=>!d.pdf);
  const getAvg=arr=>{const f=arr.filter(d=>d.totalNet!=null||d.net!=null);return f.length?(f.reduce((a,d)=>a+(d.totalNet??d.net),0)/f.length).toFixed(1):'—';};
  html += `<div class="istat-section"><div class="section-title" style="margin-bottom:12px">📄 PDF</div>
    <div class="deneme-avg-grid" style="margin-bottom:10px">
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--ayt)">${pdfli.length}</div><div class="deneme-avg-label">PDF</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--text2)">${pdfSiz.length}</div><div class="deneme-avg-label">Kitap</div></div>
    </div>
    <div class="istat-konu-item" style="margin-bottom:5px"><div class="istat-konu-name">PDF ort. net</div><span style="font-size:13px;font-weight:700;color:var(--ayt)">${getAvg(pdfli)}</span></div>
    <div class="istat-konu-item"><div class="istat-konu-name">Kitap ort. net</div><span style="font-size:13px;font-weight:700;color:var(--text)">${getAvg(pdfSiz)}</span></div>
  </div>`;

  // ── Yayınevi istatistikleri ──────────────────────────────────
  const yayineviMap = {};
  log.forEach(d => {
    if (!d.yayinevi) return;
    if (!yayineviMap[d.yayinevi]) yayineviMap[d.yayinevi] = [];
    yayineviMap[d.yayinevi].push(d);
  });
  const yayinevleri = Object.entries(yayineviMap).sort((a,b) => b[1].length - a[1].length);
  if (yayinevleri.length > 0) {
    const maxCount = yayinevleri[0][1].length;
    html += `<div class="istat-section"><div class="section-title" style="margin-bottom:12px">🏢 Yayınevi</div>`;
    yayinevleri.forEach(([yev, denemeler]) => {
      const avg = getAvg(denemeler);
      const pct = Math.round((denemeler.length / maxCount) * 100);
      html += `<div style="margin-bottom:10px">
        <div class="istat-konu-item" style="margin-bottom:4px">
          <div class="istat-konu-name" style="font-weight:600">${yev}</div>
          <span style="font-size:12px;color:var(--text2)">${denemeler.length} deneme · <span style="color:#a78bfa;font-weight:700">ort. ${avg}</span></span>
        </div>
        <div class="istat-bar-wrap"><div class="istat-bar-fill" style="width:${pct}%;background:#a78bfa"></div></div>
      </div>`;
    });
    html += `</div>`;
  }

  container.innerHTML = html;
}

// ========== TEKRAR SİSTEMİ ==========
let selectedTekrarGun = '1';

function getTekrarLog() { return JSON.parse(localStorage.getItem('yks_tekrar') || '[]'); }
function saveTekrarLog(log) { localStorage.setItem('yks_tekrar', JSON.stringify(log)); }

function loadTekrarKonular() {
  const val = document.getElementById('tekrar-ders').value;
  const [cat, dersName] = val.split('|');
  const subj = DATA[cat].find(s => s.name === dersName);
  const sel = document.getElementById('tekrar-konu');
  sel.innerHTML = '';
  if (subj) subj.topics.forEach(t => { const o = document.createElement('option'); o.value = t; o.textContent = t; sel.appendChild(o); });
}

function selectTekrarZaman(el, val) {
  selectedTekrarGun = val;
  document.querySelectorAll('.tekrar-zaman-btn').forEach(b => b.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tekrar-custom-date').style.display = val === 'custom' ? 'block' : 'none';
}

function addTekrar() {
  const dersVal = document.getElementById('tekrar-ders').value;
  const [cat, dersName] = dersVal.split('|');
  const konu = document.getElementById('tekrar-konu').value;
  const not = document.getElementById('tekrar-not').value.trim();

  let tarih;
  if (selectedTekrarGun === 'custom') {
    tarih = document.getElementById('tekrar-custom-date').value;
    if (!tarih) { showToast('⚠️ Tarih seç'); return; }
  } else {
    const d = new Date();
    d.setDate(d.getDate() + parseInt(selectedTekrarGun));
    tarih = d.toISOString().split('T')[0];
  }

  const log = getTekrarLog();
  log.push({ id: Date.now(), cat, ders: dersName, konu, tarih, not, done: false });
  saveTekrarLog(log);
  document.getElementById('tekrar-not').value = '';
  showToast('🔁 Tekrar eklendi!');
  renderTekrar();
}

function tekrarDone(id) {
  const log = getTekrarLog();
  const item = log.find(t => t.id === id);
  if (item) { item.done = true; item.doneTarih = new Date().toISOString().split('T')[0]; }
  saveTekrarLog(log);
  renderTekrar();
  showToast('✅ Tekrar tamamlandı!');
}

function tekrarSil(id) {
  const log = getTekrarLog().filter(t => t.id !== id);
  saveTekrarLog(log);
  renderTekrar();
}

function renderTekrar() {
  loadTekrarKonular();
  const log = getTekrarLog();
  const today = new Date().toISOString().split('T')[0];

  const bugun = log.filter(t => !t.done && t.tarih <= today);
  const yaklasan = log.filter(t => !t.done && t.tarih > today).sort((a,b) => a.tarih.localeCompare(b.tarih));
  const tamamlanan = log.filter(t => t.done).sort((a,b) => (b.doneTarih||'').localeCompare(a.doneTarih||'')).slice(0,10);

  // Bugün
  const bugunEl = document.getElementById('tekrarBugun');
  const sayi = document.getElementById('tekrarBugunSayi');
  sayi.textContent = bugun.length > 0 ? bugun.length + ' konu' : '';
  if (bugun.length === 0) {
    bugunEl.innerHTML = '<div class="tekrar-empty">🎉 Bugün tekrar yok, devam et!</div>';
  } else {
    bugunEl.innerHTML = '';
    bugun.forEach(t => {
      const isOverdue = t.tarih < today;
      bugunEl.innerHTML += `<div class="tekrar-card ${isOverdue?'urgent':'today'}">
        <div class="tekrar-card-info">
          <div class="tekrar-card-konu">${t.konu}</div>
          <div class="tekrar-card-ders">${t.ders} · ${t.cat}</div>
          ${t.not ? `<div class="tekrar-card-not">💬 ${t.not}</div>` : ''}
          <div class="tekrar-card-tarih" style="color:${isOverdue?'var(--danger)':'var(--accent)'}">
            ${isOverdue ? '⚠️ Gecikti: ' + formatTarih(t.tarih) : '📅 Bugün'}
          </div>
        </div>
        <div class="tekrar-card-actions">
          <div class="tekrar-done-btn" onclick="tekrarDone(${t.id})">✓ Tamam</div>
          <div class="tekrar-del-btn" onclick="tekrarSil(${t.id})">🗑</div>
        </div>
      </div>`;
    });
  }

  // Yaklaşan
  const yakEl = document.getElementById('tekrarYaklasan');
  if (yaklasan.length === 0) {
    yakEl.innerHTML = '<div class="tekrar-empty">Yaklaşan tekrar yok.</div>';
  } else {
    yakEl.innerHTML = '';
    yaklasan.slice(0, 20).forEach(t => {
      const kalan = Math.ceil((new Date(t.tarih) - new Date(today)) / (1000*60*60*24));
      yakEl.innerHTML += `<div class="tekrar-card">
        <div class="tekrar-card-info">
          <div class="tekrar-card-konu">${t.konu}</div>
          <div class="tekrar-card-ders">${t.ders} · ${t.cat}</div>
          ${t.not ? `<div class="tekrar-card-not">💬 ${t.not}</div>` : ''}
          <div class="tekrar-card-tarih" style="color:var(--text2)">${formatTarih(t.tarih)} · ${kalan} gün sonra</div>
        </div>
        <div class="tekrar-card-actions">
          <div class="tekrar-done-btn" onclick="tekrarDone(${t.id})">✓ Tamam</div>
          <div class="tekrar-del-btn" onclick="tekrarSil(${t.id})">🗑</div>
        </div>
      </div>`;
    });
  }

  // Tamamlananlar
  const tamEl = document.getElementById('tekrarTamamlanan');
  if (tamamlanan.length === 0) {
    tamEl.innerHTML = '<div class="tekrar-empty">Henüz tamamlanan yok.</div>';
  } else {
    tamEl.innerHTML = '';
    tamamlanan.forEach(t => {
      tamEl.innerHTML += `<div class="tekrar-card done">
        <div class="tekrar-card-info">
          <div class="tekrar-card-konu">✅ ${t.konu}</div>
          <div class="tekrar-card-ders">${t.ders} · ${t.cat}</div>
          <div class="tekrar-card-tarih" style="color:var(--text2)">${formatTarih(t.doneTarih||t.tarih)}</div>
        </div>
        <div class="tekrar-card-actions">
          <div class="tekrar-del-btn" onclick="tekrarSil(${t.id})">🗑</div>
        </div>
      </div>`;
    });
  }

  // Nav badge - bugün tekrar varsa
  const navTekrar = document.getElementById('nav-tekrar');
  if (bugun.length > 0) {
    navTekrar.style.position = 'relative';
    if (!document.getElementById('tekrarBadge')) {
      navTekrar.insertAdjacentHTML('beforeend', `<div id="tekrarBadge" style="position:absolute;top:4px;right:10px;background:var(--danger);color:white;font-size:9px;font-weight:800;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center">${bugun.length}</div>`);
    } else {
      document.getElementById('tekrarBadge').textContent = bugun.length;
    }
  } else {
    const badge = document.getElementById('tekrarBadge');
    if (badge) badge.remove();
  }
}

function formatTarih(iso) {
  if (!iso) return '';
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('tr-TR', {day:'numeric', month:'short'});
}
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function toggleHideDone() {
  hideDone = !hideDone;
  const ht = document.getElementById('hideToggle');
  if (ht) ht.classList.toggle('on', hideDone);
  renderSubjects();
}

function resetAll() {
  if (!confirm('Tüm ilerleme ve çalışma kayıtları sıfırlansın mı?')) return;
  state = {};
  localStorage.removeItem('yks_state');
  localStorage.removeItem('yks_worklog');
  init();
  showToast('🔄 İlerleme sıfırlandı');
}


// ========== TEST KİTABI ==========
let _tkSelectedBrans = null;
let _tkSelectedTip = null;
let _tkSelectedLabel = null;

function getTkData() {
  return JSON.parse(localStorage.getItem('yks_testkitap') || '[]');
}
function saveTkData(data) {
  localStorage.setItem('yks_testkitap', JSON.stringify(data));
}

function tkToggleBransGroup(group) {
  const body = document.getElementById('tk-brans-group-' + group);
  const arrow = document.getElementById('tk-brans-group-' + group + '-arrow');
  if (!body) return;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  if (arrow) arrow.style.transform = isOpen ? '' : 'rotate(180deg)';
}

function getTopicsForBrans(bransName, tip, label) {
  const list = tip === 'AYT' ? DATA.AYT : DATA.TYT;
  // Fen = Fizik+Kimya+Biyoloji konuları birleşik
  if (label === 'Fen' || bransName === 'Fen') {
    return [
      ...( list.find(d => d.name === 'Fizik')?.topics || [] ).map(t => '[Fizik] ' + t),
      ...( list.find(d => d.name === 'Kimya')?.topics || [] ).map(t => '[Kimya] ' + t),
      ...( list.find(d => d.name === 'Biyoloji')?.topics || [] ).map(t => '[Biyoloji] ' + t),
    ];
  }
  // Sosyal = Tarih+Coğrafya+Felsefe+Din konuları birleşik
  if (label === 'Sosyal' || bransName === 'Sosyal') {
    return [
      ...( list.find(d => d.name === 'Tarih')?.topics || [] ).map(t => '[Tarih] ' + t),
      ...( list.find(d => d.name === 'Coğrafya')?.topics || [] ).map(t => '[Coğrafya] ' + t),
      ...( list.find(d => d.name === 'Felsefe')?.topics || [] ).map(t => '[Felsefe] ' + t),
      ...( list.find(d => d.name === 'Din')?.topics || [] ).map(t => '[Din] ' + t),
    ];
  }
  const ders = list.find(d => d.name === bransName);
  return ders ? ders.topics : [];
}

function tkSelectBrans(name, tip, label) {
  const newLabel = label || name;
  // Aynı seçiliyse geri al (toggle)
  if (_tkSelectedBrans === name && _tkSelectedTip === tip && _tkSelectedLabel === newLabel) {
    _tkSelectedBrans = null;
    _tkSelectedTip = null;
    _tkSelectedLabel = null;
    document.querySelectorAll('[id^="tkchip-"]').forEach(el => {
      el.classList.remove('active');
      el.style.color = '';
      el.style.borderColor = '';
      el.style.background = '';
    });
    return;
  }
  _tkSelectedBrans = name;
  _tkSelectedTip = tip;
  _tkSelectedLabel = newLabel;
  // Tüm chip'leri sıfırla
  document.querySelectorAll('[id^="tkchip-"]').forEach(el => {
    el.classList.remove('active');
    el.style.color = '';
    el.style.borderColor = '';
    el.style.background = '';
  });
  // Seçiliyi vurgula
  const chipId = 'tkchip-' + tip + '-' + newLabel;
  const chip = document.getElementById(chipId);
  if (chip) {
    chip.classList.add('active');
    chip.style.color = 'var(--accent)';
    chip.style.borderColor = 'var(--accent)';
    chip.style.background = 'rgba(124,92,252,.15)';
  }
}

function renderTestKitapPage() {
  renderTkKitaplar();
}

function addTestKitap() {
  if (!_tkSelectedBrans || !_tkSelectedTip) return showToast('⚠️ Bir branş seç');
  const yayineviEl = document.getElementById('tk-yayinevi-input');
  const yayinevi = yayineviEl.value.trim();
  if (!yayinevi) return showToast('⚠️ Yayınevi gir');
  const topics = getTopicsForBrans(_tkSelectedBrans, _tkSelectedTip, _tkSelectedLabel);
  if (!topics.length) return showToast('⚠️ Konu bulunamadı');
  const kitap = {
    id: Date.now(),
    brans: _tkSelectedLabel || _tkSelectedBrans,
    tip: _tkSelectedTip,
    yayinevi,
    konular: topics.map(t => ({ konu: t, bitti: false }))
  };
  const data = getTkData();
  data.push(kitap);
  saveTkData(data);
  yayineviEl.value = '';
  _tkSelectedBrans = null;
  _tkSelectedTip = null;
  _tkSelectedLabel = null;
  document.querySelectorAll('[id^="tkchip-"]').forEach(el => {
    el.classList.remove('active');
    el.style.color = '';
    el.style.borderColor = '';
    el.style.background = '';
  });
  renderTkKitaplar();
  showToast('📒 Kitap eklendi!');
}

function tkToggleKonu(kitapId, konuIdx) {
  const data = getTkData();
  const kitap = data.find(k => k.id === kitapId);
  if (!kitap) return;
  kitap.konular[konuIdx].bitti = !kitap.konular[konuIdx].bitti;
  saveTkData(data);
  _renderTkKitap(kitapId);
}

function tkDeleteKitap(kitapId) {
  
  saveTkData(getTkData().filter(k => k.id !== kitapId));
  renderTkKitaplar();
  showToast('🗑️ Kitap silindi');
}

function tkToggleExpand(kitapId) {
  const el = document.getElementById('tk-body-' + kitapId);
  if (!el) return;
  const isHidden = el.style.display === 'none';
  el.style.display = isHidden ? 'block' : 'none';
  const arrow = document.getElementById('tk-arrow-' + kitapId);
  if (arrow) arrow.textContent = isHidden ? '▲' : '▼';
}

function tkToggleEdit(kitapId) {
  const data = getTkData();
  const kitap = data.find(k => k.id === kitapId);
  if (!kitap) return;
  kitap._editing = !kitap._editing;
  saveTkData(data);
  _renderTkKitap(kitapId);
}

function tkMoveKonu(kitapId, idx, dir) {
  const data = getTkData();
  const kitap = data.find(k => k.id === kitapId);
  if (!kitap) return;
  const newIdx = idx + dir;
  if (newIdx < 0 || newIdx >= kitap.konular.length) return;
  const tmp = kitap.konular[idx];
  kitap.konular[idx] = kitap.konular[newIdx];
  kitap.konular[newIdx] = tmp;
  saveTkData(data);
  _renderTkKitap(kitapId);
}

function tkDeleteKonu(kitapId, idx) {
  const data = getTkData();
  const kitap = data.find(k => k.id === kitapId);
  if (!kitap) return;
  kitap.konular.splice(idx, 1);
  saveTkData(data);
  _renderTkKitap(kitapId);
}

function tkAddKonu(kitapId) {
  const input = document.getElementById('tk-newkonu-' + kitapId);
  if (!input) return;
  const val = input.value.trim();
  if (!val) return;
  const data = getTkData();
  const kitap = data.find(k => k.id === kitapId);
  if (!kitap) return;
  kitap.konular.push({ konu: val, bitti: false });
  saveTkData(data);
  input.value = '';
  _renderTkKitap(kitapId);
}

function _renderTkKitap(kitapId) {
  const data = getTkData();
  const kitap = data.find(k => k.id === kitapId);
  if (!kitap) return;
  const container = document.getElementById('tk-card-' + kitapId);
  if (!container) return;
  container.outerHTML = _buildKitapHTML(kitap);
  // Expand durumunu koru
  const body = document.getElementById('tk-body-' + kitapId);
  if (body) body.style.display = 'block';
  const arrow = document.getElementById('tk-arrow-' + kitapId);
  if (arrow) arrow.textContent = '▲';
}

function _buildKitapHTML(kitap) {
  const total = kitap.konular.length;
  const done = kitap.konular.filter(k => k.bitti).length;
  const pct = total ? Math.round(done / total * 100) : 0;
  const ders = (kitap.tip === 'AYT' ? DATA.AYT : DATA.TYT).find(d => d.name === kitap.brans)
           || [...DATA.TYT, ...DATA.AYT].find(d => d.name === kitap.brans);
  const color = ders ? ders.color : 'var(--accent)';
  const editing = !!kitap._editing;

  const konularHTML = kitap.konular.map((k, i) => {
    if (editing) {
      return `
        <div style="display:flex;align-items:center;gap:8px;padding:7px 6px;border-radius:10px;
                    background:var(--surface2);margin-bottom:4px">
          <div style="display:flex;flex-direction:column;gap:2px;flex-shrink:0">
            <button onclick="tkMoveKonu(${kitap.id},${i},-1)" ${i===0?'disabled':''} 
              style="background:none;border:none;color:${i===0?'var(--text3)':'var(--text2)'};cursor:${i===0?'default':'pointer'};
                     font-size:13px;padding:0;line-height:1">▲</button>
            <button onclick="tkMoveKonu(${kitap.id},${i},1)" ${i===kitap.konular.length-1?'disabled':''}
              style="background:none;border:none;color:${i===kitap.konular.length-1?'var(--text3)':'var(--text2)'};
                     cursor:${i===kitap.konular.length-1?'default':'pointer'};font-size:13px;padding:0;line-height:1">▼</button>
          </div>
          <span style="flex:1;font-size:13px;color:var(--text)">${k.konu}</span>
          <button onclick="tkDeleteKonu(${kitap.id},${i})"
            style="background:none;border:none;color:#ff4d6a;cursor:pointer;font-size:16px;padding:0;flex-shrink:0">✕</button>
        </div>`;
    }
    return `
      <div onclick="tkToggleKonu(${kitap.id},${i})"
        style="display:flex;align-items:center;gap:12px;padding:10px 8px;border-radius:10px;cursor:pointer;
               background:${k.bitti?'rgba(124,92,252,.07)':'transparent'};margin-bottom:2px;transition:background .15s">
        <div style="width:20px;height:20px;border-radius:6px;border:2px solid ${k.bitti?color:'var(--border)'};
                    background:${k.bitti?color:'transparent'};display:flex;align-items:center;justify-content:center;
                    flex-shrink:0;transition:all .15s">
          ${k.bitti?'<span style="color:#fff;font-size:12px;font-weight:900">✓</span>':''}
        </div>
        <span style="font-size:14px;color:${k.bitti?'var(--text3)':'var(--text)'};
                     text-decoration:${k.bitti?'line-through':'none'};transition:all .15s">${k.konu}</span>
      </div>`;
  }).join('');

  const addRowHTML = editing ? `
    <div style="display:flex;gap:8px;margin-top:8px">
      <input id="tk-newkonu-${kitap.id}" class="deneme-input" placeholder="Yeni konu adı…"
        style="flex:1;font-size:13px" onkeydown="if(event.key==='Enter')tkAddKonu(${kitap.id})">
      <button onclick="tkAddKonu(${kitap.id})"
        style="padding:0 16px;border-radius:12px;border:none;background:var(--accent);color:#fff;
               font-size:18px;cursor:pointer;flex-shrink:0">+</button>
    </div>` : '';

  return `
  <div class="section" id="tk-card-${kitap.id}" style="margin-top:14px;padding:0;overflow:hidden">
    <div onclick="tkToggleExpand(${kitap.id})" style="padding:16px 18px;cursor:pointer;display:flex;align-items:center;gap:12px">
      <div style="flex:1;min-width:0">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
          <span style="font-size:15px;font-weight:800;color:var(--text)">${kitap.brans}</span>
          <span style="font-size:11px;color:var(--text3);background:var(--surface2);border-radius:8px;padding:2px 7px">${kitap.tip||'TYT'}</span>
          <span style="font-size:12px;color:var(--text3);background:var(--surface2);border-radius:8px;padding:2px 8px">${kitap.yayinevi}</span>
        </div>
        <div style="font-size:12px;color:var(--text3);margin-bottom:8px">${done}/${total} konu tamamlandı</div>
        <div style="height:5px;background:var(--surface2);border-radius:99px;overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${color};border-radius:99px;transition:width .3s"></div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0">
        <span style="font-size:18px;font-weight:800;color:${color}">${pct}%</span>
        <span id="tk-arrow-${kitap.id}" style="font-size:11px;color:var(--text3)">▼</span>
      </div>
    </div>
    <div id="tk-body-${kitap.id}" style="display:none;border-top:1px solid var(--border)">
      <div style="padding:10px 14px">
        ${konularHTML}
        ${addRowHTML}
      </div>
      <div style="padding:8px 14px 14px;display:flex;justify-content:space-between;align-items:center">
        <button onclick="event.stopPropagation();tkToggleEdit(${kitap.id})"
          style="background:${editing?'rgba(124,92,252,.18)':'var(--surface2)'};color:${editing?'var(--accent)':'var(--text2)'};
                 border:1.5px solid ${editing?'var(--accent)':'var(--border)'};border-radius:10px;padding:7px 14px;
                 font-size:12px;cursor:pointer;font-family:inherit;font-weight:600">
          ${editing?'✅ Düzenlemeyi Bitir':'✏️ Düzenle'}
        </button>
        <button onclick="tkDeleteKitap(${kitap.id})"
          style="background:rgba(255,77,106,.12);color:#ff4d6a;border:none;border-radius:10px;padding:7px 14px;
                 font-size:12px;cursor:pointer;font-family:inherit;font-weight:600">🗑️ Kitabı Sil</button>
      </div>
    </div>
  </div>`;
}

function renderTkKitaplar() {
  const data = getTkData();
  const container = document.getElementById('tk-kitaplar');
  if (!container) return;
  if (!data.length) {
    container.innerHTML = '<div style="text-align:center;color:var(--text3);padding:32px 0;font-size:14px">Henüz kitap eklenmedi</div>';
    return;
  }
  container.innerHTML = data.map(_buildKitapHTML).join('');
}

init();
setTimeout(() => renderTekrar(), 200);
setTimeout(() => refreshYayineviSelects(), 100);
</script>

    log.unshift({ id: Date.now(), type:'brans', name, date, ders:dersName, cat, net, dogru, yanlis, bos, konuYanlis, konuBos, konular:{...konuState}, sure, yer, pdf });
    ['b-name','b-dogru','b-yanlis','b-bos','b-sure'].forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
    const nd = document.getElementById('b-net-val'); if(nd) nd.textContent = '—';
    pdfState.b = false;
    document.getElementById('b-pdf-toggle').classList.remove('on');
    document.getElementById('b-pdf-label').textContent = 'PDF değil';
    document.getElementById('b-pdf-label').style.color = 'var(--text2)';
    konuState = {};
  }

  saveDenemeLog(log);
  showToast('✅ Deneme kaydedildi!');
  switchDenemeTab(tip);
}

function openKonuModal(mode) {
  modalMode = mode;
  // konuState'i sıfırlama — form değiştirilmeden modal tekrar açılabilsin
  const modal = document.getElementById('konuModal');
  const body = document.getElementById('modalBody');
  const title = document.getElementById('modalTitle');
  const saveBtn = document.getElementById('modalSaveBtn');

  let groups = [];
  if (mode === 'tyt') {
    title.textContent = 'TYT — Yanlış / Boş İşaretle';
    saveBtn.style.background = 'var(--accent)';
    groups = DATA.TYT.map(s => ({ ders: s.name, icon: s.icon, topics: s.topics }));
  } else if (mode === 'ayt') {
    title.textContent = 'AYT — Yanlış / Boş İşaretle';
    saveBtn.style.background = 'var(--ayt)';
    groups = DATA.AYT.map(s => ({ ders: s.name, icon: s.icon, topics: s.topics }));
  } else if (mode.startsWith('single-')) {
    // single-TYT-Matematik, single-AYT-Fizik vb.
    const parts = mode.slice(7).split('-'); // ['TYT','Matematik'] veya ['AYT','Biyoloji']
    const cat = parts[0];
    const dersName = parts.slice(1).join('-'); // Coğrafya gibi
    title.textContent = dersName + ' (' + cat + ') — Yanlış / Boş İşaretle';
    saveBtn.style.background = '#8b5cf6';
    const subj = DATA[cat]?.find(s => s.name === dersName);
    if (subj) groups = [{ ders: subj.name, icon: subj.icon||'', topics: subj.topics }];
  } else if (mode.startsWith('brans-')) {
    const bsTab = mode.slice(6);
    const bsColor = BS_COLORS[bsTab] || '#8b5cf6';
    const tabLabels = {'tyt-mat':'TYT Matematik','ayt-mat':'AYT Matematik','tyt-fen':'TYT Fen','ayt-fen':'AYT Fen','tyt-sos':'TYT Sosyal'};
    title.textContent = (tabLabels[bsTab]||bsTab) + ' — Yanlış / Boş İşaretle';
    saveBtn.style.background = bsColor;
    const fields = MULTI_FIELDS[bsTab] || [];
    fields.forEach(([, ders]) => {
      const found = [...DATA.TYT, ...DATA.AYT].find(s => s.name === ders);
      if (found) groups.push({ ders: found.name, icon: found.icon||'', topics: found.topics });
    });
  } else {
    const val = document.getElementById('b-ders').value;
    const [dersName, cat] = val.split('|');
    title.textContent = dersName + ' — Yanlış / Boş İşaretle';
    saveBtn.style.background = '#8b5cf6';
    const subj = DATA[cat].find(s => s.name === dersName);
    if (subj) groups = [{ ders: subj.name, icon: subj.icon, topics: subj.topics }];
  }

  body.innerHTML = '';
  groups.forEach(g => {
    const wrap = document.createElement('div');
    const titleDiv = document.createElement('div');
    titleDiv.className = 'yb-ders-title';
    titleDiv.textContent = g.icon + ' ' + g.ders;
    wrap.appendChild(titleDiv);

    g.topics.forEach(topic => {
      const key = g.ders + '|' + topic;
      if (!konuState[key]) konuState[key] = null; // null = işaretsiz/doğru
      const safeId = 'yb-' + encodeURIComponent(key).replace(/[^a-zA-Z0-9]/g,'_');

      const row = document.createElement('div');
      row.className = 'yb-konu-row';

      const cur = konuState[key];
      row.innerHTML = `
        <span class="yb-konu-name">${topic}</span>
        <div class="yb-btn ${cur==='y'?'sel-y':''}" id="${safeId}-y" onclick="setYB('${key}','y')">✗</div>
        <div class="yb-btn ${cur==='b'?'sel-b':''}" id="${safeId}-b" onclick="setYB('${key}','b')">○</div>`;
      wrap.appendChild(row);
    });
    body.appendChild(wrap);
  });

  modal.style.display = 'block';
}

function setYB(key, val) {
  // Toggle: aynı butona basılırsa işareti kaldır
  konuState[key] = konuState[key] === val ? null : val;
  const cur = konuState[key];
  const safeId = 'yb-' + encodeURIComponent(key).replace(/[^a-zA-Z0-9]/g,'_');
  const btnY = document.getElementById(safeId + '-y');
  const btnB = document.getElementById(safeId + '-b');
  if (btnY) btnY.className = 'yb-btn' + (cur==='y' ? ' sel-y' : '');
  if (btnB) btnB.className = 'yb-btn' + (cur==='b' ? ' sel-b' : '');
}

function saveKonuModal() {
  // Sadece konuState'i kapat, deneme kaydı form'dan yapılıyor
  closeKonuModal();
  const y = Object.values(konuState).filter(v=>v==='y').length;
  const b = Object.values(konuState).filter(v=>v==='b').length;
  showToast(`📌 ${y} yanlış, ${b} boş işaretlendi`);
}

function closeKonuModal() {
  document.getElementById('konuModal').style.display = 'none';
  modalMode = null;
}


function deleteDeneme(id) {
  const log = getDenemeLog();
  const item = log.find(d => d.id === id);
  const filtered = log.filter(d => d.id !== id);
  saveDenemeLog(filtered);
  if (item && item.type === 'brans2') {
    renderBransList(item.tab);
  } else {
    renderDenemeList(currentDenemeTab);
    renderDenemeAvg(currentDenemeTab);
  }
  showToast('🗑 Deneme silindi');
}

function metaChips(d) {
  const yerEmoji = { ev:'🏠', dershane:'🏫', kutuphane:'📚' };
  let chips = '';
  if (d.soruSayisi) chips += `<span style="background:rgba(124,92,252,.15);color:var(--accent);padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700">${d.soruSayisi} soru</span>`;
  if (d.sure) chips += `<span style="background:rgba(45,222,152,.12);color:var(--accent3);padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700">⏱ ${d.sure} dk</span>`;
  if (d.yer) chips += `<span style="background:rgba(255,255,255,.07);color:var(--text2);padding:2px 7px;border-radius:20px;font-size:10px">${yerEmoji[d.yer]||'📍'} ${d.yer.charAt(0).toUpperCase()+d.yer.slice(1)}</span>`;
  if (d.pdf) chips += `<span style="background:rgba(245,166,35,.15);color:var(--ayt);padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700">📄 PDF</span>`;
  if (d.yayinevi) chips += `<span style="background:rgba(167,139,250,.15);color:#a78bfa;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:700">🏢 ${d.yayinevi}</span>`;
  return chips ? `<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px">${chips}</div>` : '';
}

function renderDenemeAvg(tab) {
  const log = getDenemeLog().filter(d => d.type === tab);
  const card = document.getElementById('dAvgCard');
  const grid = document.getElementById('dAvgGrid');
  if (log.length === 0) { card.style.display = 'none'; return; }
  card.style.display = 'block';

  if (tab === 'tyt') {
    const avgTotal = (log.reduce((a,d) => a + d.totalNet, 0) / log.length).toFixed(1);
    let html = `<div class="deneme-avg-item" style="grid-column:span 2"><div class="deneme-avg-val" style="color:var(--accent)">${avgTotal}</div><div class="deneme-avg-label">Ort. Toplam Net</div></div>`;
    const colors = { 'Türkçe':'#a78bfa','Matematik':'#60a5fa','Geometri':'#fb923c','Tarih':'#e879a0','Coğrafya':'#34d399','Felsefe':'#fb923c','Din':'#fbbf24','Fizik':'#f472b6','Kimya':'#34d399','Biyoloji':'#fbbf24' };
    DATA.TYT.forEach(s => {
      const avg = (log.reduce((a,d) => a + (d.dersNetler?.[s.name]||0), 0) / log.length).toFixed(1);
      html += `<div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${colors[s.name]||'var(--text)'}">${avg}</div><div class="deneme-avg-label" style="font-size:9px">${s.name}</div></div>`;
    });
    grid.innerHTML = html;
  } else if (tab === 'ayt') {
    const avgTotal = (log.reduce((a,d) => a + d.totalNet, 0) / log.length).toFixed(1);
    let html = `<div class="deneme-avg-item" style="grid-column:span 2"><div class="deneme-avg-val" style="color:var(--ayt)">${avgTotal}</div><div class="deneme-avg-label">Ort. Toplam Net</div></div>`;
    const colors = { 'Matematik':'#60a5fa','Geometri':'#fb923c','Fizik':'#f472b6','Kimya':'#34d399','Biyoloji':'#fbbf24' };
    DATA.AYT.forEach(s => {
      const avg = (log.reduce((a,d) => a + (d.dersNetler?.[s.name]||0), 0) / log.length).toFixed(1);
      html += `<div class="deneme-avg-item"><div class="deneme-avg-val" style="color:${colors[s.name]||'var(--text)'}">${avg}</div><div class="deneme-avg-label" style="font-size:9px">${s.name}</div></div>`;
    });
    grid.innerHTML = html;
  } else {
    const avgNet = (log.reduce((a,d) => a + (d.net||0), 0) / log.length).toFixed(2);
    grid.innerHTML = `
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent2)">${avgNet}</div><div class="deneme-avg-label">Ort. Net</div></div>
      <div class="deneme-avg-item"><div class="deneme-avg-val" style="color:var(--accent3)">${log.length}</div><div class="deneme-avg-label">Deneme</div></div>`;
  }
}

function renderDenemeList(tab) {
  const log = getDenemeLog().filter(d => d.type === tab);
  const list = document.getElementById('dList-' + tab);
  if (!list) return;
  const color = tab === 'tyt' ? 'var(--accent)' : tab === 'ayt' ? 'var(--ayt)' : '#8b5cf6';

  if (log.length === 0) {
    list.innerHTML = `<div class="deneme-empty"><div class="deneme-empty-icon"></div>Henüz deneme eklenmedi.</div>`;
    return;
  }

  list.innerHTML = '';
  log.forEach(d => {
    const card = document.createElement('div');
    card.className = 'deneme-card';

    // Y/B konu özeti
    let ybSummary = '';
    if (d.konular) {
      const vals = Object.values(d.konular).filter(v => v !== null);
      const yy = vals.filter(v=>v==='y').length;
      const bb = vals.filter(v=>v==='b').length;
      if (yy > 0 || bb > 0) {
        ybSummary = `<div style="display:flex;gap:12px;font-size:11px;margin-top:8px;padding:6px 10px;background:var(--surface2);border-radius:10px">
          <span style="color:var(--danger)">✗ ${yy} yanlış</span>
          <span style="color:var(--text2)">○ ${bb} boş</span>
        </div>`;
      }
    }

    if (tab === 'tyt' || tab === 'ayt') {
      const maxNet = tab === 'tyt' ? 120 : 160;
      const pct = Math.min(100, Math.max(0, Math.round((d.totalNet / maxNet) * 100)));
      const DATA_SRC = tab === 'tyt' ? DATA.TYT : DATA.AYT;
      const colors = { 'Türkçe':'#a78bfa','Matematik':'#60a5fa','Geometri':'#fb923c','Tarih':'#e879a0','Coğrafya':'#34d399','Felsefe':'#fb7c0a','Din':'#fbbf24','Fizik':'#f472b6','Kimya':'#34d399','Biyoloji':'#fbbf24' };
      let scoresHtml = `<div class="deneme-score-item"><div class="deneme-score-val" style="color:${color}">${d.totalNet}</div><div class="deneme-score-label">Toplam</div></div>`;
      // TYT/AYT skor satırları
      DATA_SRC.forEach(s => {
        const net = d.dersNetler?.[s.name] ?? '—';
        scoresHtml += `<div class="deneme-score-item"><div class="deneme-score-val" style="color:${colors[s.name]||'var(--text)'};">${net}</div><div class="deneme-score-label" style="font-size:9px">${s.name}</div></div>`;
      });
      card.innerHTML = `
        <div class="deneme-card-top">
          <div><div class="deneme-card-title">${d.name}</div><div class="deneme-card-date">${d.date}</div></div>
          <div class="deneme-card-delete" onclick="deleteDeneme(${d.id})">🗑</div>
        </div>
        <div class="deneme-scores">${scoresHtml}</div>
        ${ybSummary}
        ${metaChips(d)}
        <div style="font-size:11px;color:var(--text2);margin-top:8px;margin-bottom:4px">%${pct}</div>
        <div class="deneme-net-bar"><div class="deneme-net-fill" style="width:${pct}%;background:${color}"></div></div>`;
    } else {
      card.innerHTML = `
        <div class="deneme-card-top">
          <div><div class="deneme-card-title">🔬 ${d.name}</div><div class="deneme-card-date">${d.date} · ${d.ders} (${d.cat})</div></div>
          <div class="deneme-card-delete" onclick="deleteDeneme(${d.id})">🗑</div>
        </div>
        <div class="deneme-scores">
          <div class="deneme-score-item"><div class="deneme-score-val" style="color:#8b5cf6">${d.net}</div><div class="deneme-score-label">Net</div></div>
          ${d.dogru!=null?`<div class="deneme-score-item"><div class="deneme-score-val" style="color:var(--accent3)">${d.dogru}</div><div class="deneme-score-label">Doğru</div></div>`:''}
          ${d.yanlis!=null?`<div class="deneme-score-item"><div class="deneme-score-val" style="color:var(--danger)">${d.yanlis}</div><div class="deneme-score-label">Yanlış</div></div>`:''}
          ${d.bos!=null?`<div class="deneme-score-item"><div class="deneme-score-val" style="color:var(--text2)">${d.bos}</div><div class="deneme-score-label">Boş</div></div>`:''}
        </div>
        ${ybSummary}
        ${metaChips(d)}`;
    }
    list.appendChild(card);
  });
}


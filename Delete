  const idx = istatFiltreler.yer.indexOf(yer);
  if (idx === -1) istatFiltreler.yer.push(yer);
  else istatFiltreler.yer.splice(idx, 1);
  renderIstatistik();
}

function toggleIstatPdf(val) {
  istatFiltreler.pdf = istatFiltreler.pdf === val ? null : val;

// ========== PLAN ==========
let currentPlanTab = 'gunluk';

function getPlanLog() {
  const raw = JSON.parse(localStorage.getItem('yks_plan') || '{}');
  return { gunluk: raw.gunluk||[], haftalik: raw.haftalik||[], aylik: raw.aylik||[], gunler: raw.gunler||{} };
}
function savePlanLog(log) { localStorage.setItem('yks_plan', JSON.stringify(log)); }



function switchPlanTab(tab) {
  currentPlanTab = tab;
  ['gunluk','haftalik','aylik'].forEach(t => {
    document.getElementById('plan-' + t).style.display = t === tab ? 'block' : 'none';
    const btn = document.getElementById('plantab-' + t);
    btn.className = 'deneme-tab' + (t === tab ? ' active-genel' : '');
  });
  renderPlan();
}

function _todayKey() { return dateKey(new Date()); }

function addPlanGorev(tip) {
  // Günlük için bugünün dateKey'ini kullan (haftalık/aylık ile aynı veri)
  const input = document.getElementById('planGunlukInput');
  const text = input?.value.trim();
  if (!text) return;
  const dk = _todayKey();
  const log = getPlanLog();
  if (!log.gunler[dk]) log.gunler[dk] = [];
  log.gunler[dk].push({ id: Date.now(), text, done: false });
  savePlanLog(log);
  input.value = '';
  renderPlanList('gunluk', 'planGunlukList');
}

function togglePlanGorev(id) {
  const dk = _todayKey();
  const log = getPlanLog();
  const item = (log.gunler[dk]||[]).find(x=>x.id===id);
  if (item) item.done = !item.done;
  savePlanLog(log);
  renderPlanList('gunluk', 'planGunlukList');
}

function deletePlanGorev(id) {
  const dk = _todayKey();
  const log = getPlanLog();
  log.gunler[dk] = (log.gunler[dk]||[]).filter(x=>x.id!==id);
  savePlanLog(log);
  renderPlanList('gunluk', 'planGunlukList');
}

function renderPlanList(tip, containerId) {
  // Günlük için bugünün gunler[dk] verisini göster
  const el = document.getElementById(containerId);
  if (!el) return;
  const log = getPlanLog();
  const dk = _todayKey();
  const items = log.gunler[dk] || [];
  if (items.length === 0) {
    el.innerHTML = `<div style="text-align:center;padding:24px 0;color:var(--text2);font-size:13px">Henüz görev yok 📝</div>`;
    return;
  }
  const bekleyen   = items.filter(x => !x.done);
  const tamamlanan = items.filter(x => x.done);
  let html = '';
  bekleyen.forEach(item => {
    html += `<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--surface);border-radius:14px;margin-bottom:8px;border:1px solid var(--border)">
      <div onclick="togglePlanGorev(${item.id})" style="width:22px;height:22px;border-radius:50%;border:2px solid var(--accent);cursor:pointer;flex-shrink:0"></div>
      <div style="flex:1;font-size:14px;color:var(--text)">${item.text}</div>
      <div onclick="deletePlanGorev(${item.id})" style="color:var(--danger);cursor:pointer;font-size:16px;flex-shrink:0">✕</div>
    </div>`;
  });
  if (tamamlanan.length) {
    html += `<div style="font-size:11px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin:12px 0 8px">✅ Tamamlanan (${tamamlanan.length})</div>`;
    tamamlanan.forEach(item => {
      html += `<div style="display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--surface2);border-radius:14px;margin-bottom:8px;opacity:0.6">
        <div onclick="togglePlanGorev(${item.id})" style="width:22px;height:22px;border-radius:50%;background:var(--accent);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px">✓</div>
        <div style="flex:1;font-size:14px;color:var(--text2);text-decoration:line-through">${item.text}</div>
        <div onclick="deletePlanGorev(${item.id})" style="color:var(--danger);cursor:pointer;font-size:16px;flex-shrink:0">✕</div>
      </div>`;
    });
  }
  el.innerHTML = html;
}

function renderPlan() {
  _renderPlan();
}

const AYLAR = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
const GUNLER_UZUN = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
const GUNLER_KISA = ['Pzt','Sal','Çar','Per','Cum','Cmt','Paz'];

function dateKey(d) {
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

let _secilenHafta = null;  // haftalık seçili gün key
let _secilenAy   = null;   // aylık seçili gün key

function _renderPlan() {
  const bugun = new Date();

  // ── Günlük ─────────────────────────────────────────────
  const tarihEl = document.getElementById('planGunlukTarih');
  if (tarihEl) tarihEl.innerHTML = `${GUNLER_UZUN[bugun.getDay()]}, ${bugun.getDate()} ${AYLAR[bugun.getMonth()]} ${bugun.getFullYear()}`;
  renderPlanList('gunluk', 'planGunlukList');

  // ── Haftalık ───────────────────────────────────────────
  _renderHaftalikTakvim();
  _renderGunDetay('haftalik', _secilenHafta);

  // ── Aylık ──────────────────────────────────────────────
  _renderAylikTakvim();
  _renderGunDetay('aylik', _secilenAy);
}

function _renderHaftalikTakvim() {
  const el = document.getElementById('planHaftalikTakvim');
  if (!el) return;
  const bugun = new Date();
  const gun = bugun.getDay();
  const pzt = new Date(bugun); pzt.setDate(bugun.getDate() - (gun===0?6:gun-1));
  const paz = new Date(pzt); paz.setDate(pzt.getDate()+6);
  const log = getPlanLog();

  let hw = `<div style="font-size:12px;color:var(--text2);font-weight:700;margin-bottom:10px">${pzt.getDate()} ${AYLAR[pzt.getMonth()]} – ${paz.getDate()} ${AYLAR[paz.getMonth()]}</div>`;
  hw += `<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px">`;
  for (let i=0; i<7; i++) {
    const d = new Date(pzt); d.setDate(pzt.getDate()+i);
    const dk = dateKey(d);
    const isToday    = d.toDateString() === bugun.toDateString();
    const isSelected = _secilenHafta === dk;
    const gorevler   = log.gunler?.[dk] || [];
    const tamam      = gorevler.filter(x=>x.done).length;
    const dot = gorevler.length > 0
      ? `<div style="font-size:8px;margin-top:3px;color:${tamam===gorevler.length?'#4ade80':'#c4b5fd'}">${tamam}/${gorevler.length}</div>`
      : `<div style="font-size:8px;margin-top:3px;color:transparent">·</div>`;

    let bg, border, labelColor, numColor;
    if (isSelected) {
      bg='var(--accent)'; border='2px solid var(--accent)'; labelColor='#fff'; numColor='#fff';
    } else if (isToday) {
      bg='rgba(124,92,252,.15)'; border='1.5px solid var(--accent)'; labelColor='var(--accent)'; numColor='var(--accent)';
    } else {
      bg='var(--surface2)'; border='1px solid var(--border)'; labelColor='var(--text2)'; numColor='var(--text)';
    }

    hw += `<div onclick="selectPlanGun('${dk}','haftalik')" style="text-align:center;padding:8px 2px;border-radius:10px;cursor:pointer;background:${bg};border:${border}">
      <div style="font-size:9px;color:${labelColor};font-weight:700">${GUNLER_KISA[i]}</div>
      <div style="font-size:15px;font-weight:800;color:${numColor};margin-top:1px">${d.getDate()}</div>
      ${dot}
    </div>`;
  }
  hw += `</div>`;
  el.innerHTML = hw;
}

function _renderAylikTakvim() {
  const el = document.getElementById('planAylikTakvim');
  if (!el) return;
  const bugun = new Date();
  const yil = bugun.getFullYear(), ay = bugun.getMonth();
  const ilkGun = new Date(yil, ay, 1).getDay();
  const baslangic = ilkGun===0 ? 6 : ilkGun-1;
  const sonGun = new Date(yil, ay+1, 0).getDate();
  const log = getPlanLog();

  let cal = `<div style="font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:var(--accent);margin-bottom:10px">${AYLAR[ay]} ${yil}</div>`;
  cal += `<div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:4px">`;
  GUNLER_KISA.forEach(k => { cal += `<div style="text-align:center;font-size:9px;font-weight:700;color:var(--text2);padding:4px 0">${k}</div>`; });
  cal += `</div><div style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px">`;
  for (let i=0; i<baslangic; i++) cal += `<div></div>`;
  for (let g=1; g<=sonGun; g++) {
    const d = new Date(yil, ay, g);
    const dk = dateKey(d);
    const isToday    = g===bugun.getDate();
    const isSelected = _secilenAy===dk;
    const hg = (baslangic+g-1)%7;
    const isWeekend  = hg===5||hg===6;
    const gorevler   = log.gunler?.[dk]||[];
    const tamam      = gorevler.filter(x=>x.done).length;
    const dot = gorevler.length>0
      ? `<div style="width:5px;height:5px;border-radius:50%;background:${tamam===gorevler.length?'#4ade80':'var(--accent)'};margin:2px auto 0"></div>` : '';

    let bg, color, fw;
    if (isSelected)     { bg='var(--accent)';        color='#fff';             fw='800'; }
    else if (isToday)   { bg='rgba(124,92,252,.25)'; color='var(--accent)';   fw='800'; }
    else if (isWeekend) { bg='var(--surface2)';       color='var(--accent3)';  fw='400'; }
    else                { bg='var(--surface2)';       color='var(--text)';     fw='400'; }

    cal += `<div onclick="selectPlanGun('${dk}','aylik')" style="text-align:center;padding:5px 2px;border-radius:8px;cursor:pointer;background:${bg}">
      <div style="font-size:12px;font-weight:${fw};color:${color}">${g}</div>
      ${dot}
    </div>`;
  }
  cal += `</div>`;
  el.innerHTML = cal;
}

function selectPlanGun(dk, context) {
  if (context === 'haftalik') {
    _secilenHafta = _secilenHafta===dk ? null : dk;
    _renderHaftalikTakvim();
    _renderGunDetay('haftalik', _secilenHafta);
  } else {
    _secilenAy = _secilenAy===dk ? null : dk;
    _renderAylikTakvim();
    _renderGunDetay('aylik', _secilenAy);
  }
}

function _renderGunDetay(context, dk) {
  const containerId = context==='haftalik' ? 'planHaftalikGunDetay' : 'planAylikGunDetay';
  const el = document.getElementById(containerId);
  if (!el) return;
  if (!dk) { el.innerHTML=''; return; }

  const d = new Date(dk+'T00:00:00');
  const baslik = `${GUNLER_UZUN[d.getDay()]}, ${d.getDate()} ${AYLAR[d.getMonth()]}`;
  const log = getPlanLog();
  const items = log.gunler[dk]||[];
  const bekleyen   = items.filter(x=>!x.done);
  const tamamlanan = items.filter(x=>x.done);

  let listHtml = '';
  if (items.length===0) {
    listHtml = `<div style="text-align:center;color:var(--text2);font-size:13px;padding:14px 0">Henüz görev yok 📝</div>`;
  } else {
    bekleyen.forEach(item => {
      listHtml += `<div style="display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--surface);border-radius:13px;margin-bottom:7px;border:1px solid var(--border)">
        <div onclick="toggleGunGorev('${dk}',${item.id},'${context}')" style="width:20px;height:20px;border-radius:50%;border:2px solid var(--accent);cursor:pointer;flex-shrink:0"></div>
        <div style="flex:1;font-size:13px;color:var(--text)">${item.text}</div>
        <div onclick="deleteGunGorev('${dk}',${item.id},'${context}')" style="color:var(--danger);cursor:pointer;font-size:15px;padding:2px 4px">✕</div>
      </div>`;
    });
    if (tamamlanan.length) {
      listHtml += `<div style="font-size:10px;color:var(--text2);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin:10px 0 6px">✅ Tamamlanan (${tamamlanan.length})</div>`;
      tamamlanan.forEach(item => {
        listHtml += `<div style="display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--surface2);border-radius:13px;margin-bottom:7px;opacity:.6">
          <div onclick="toggleGunGorev('${dk}',${item.id},'${context}')" style="width:20px;height:20px;border-radius:50%;background:#4ade80;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;color:#000">✓</div>
          <div style="flex:1;font-size:13px;color:var(--text2);text-decoration:line-through">${item.text}</div>
          <div onclick="deleteGunGorev('${dk}',${item.id},'${context}')" style="color:var(--danger);cursor:pointer;font-size:15px;padding:2px 4px">✕</div>
        </div>`;
      });
    }
  }

  el.innerHTML = `<div style="background:var(--surface2);border-radius:16px;padding:16px;border:1.5px solid var(--accent);margin-top:4px">
    <div style="font-family:'Syne',sans-serif;font-size:15px;font-weight:800;color:var(--accent);margin-bottom:12px">${baslik}</div>
    <div id="gunDetayList-${dk}">${listHtml}</div>
    <div style="display:flex;gap:8px;margin-top:10px">
      <input class="deneme-input" id="gunDetayInput-${dk}" placeholder="Görev ekle..." style="flex:1;font-size:13px" onkeydown="if(event.key==='Enter')addGunGorev('${dk}','${context}')">
      <button class="timer-btn-start" style="padding:9px 14px;border-radius:12px;border:none;cursor:pointer;font-size:16px" onclick="addGunGorev('${dk}','${context}')">+</button>
    </div>
  </div>`;
}

function addGunGorev(dk, context) {
  const input = document.getElementById(`gunDetayInput-${dk}`);
  const text = input?.value.trim();
  if (!text) return;
  const log = getPlanLog();
  if (!log.gunler[dk]) log.gunler[dk]=[];
  log.gunler[dk].push({id:Date.now(), text, done:false});
  savePlanLog(log);
  input.value='';
  _renderGunDetay(context, dk);
  if (context==='haftalik') _renderHaftalikTakvim();
  else _renderAylikTakvim();
}

function toggleGunGorev(dk, id, context) {
  const log = getPlanLog();
  const item = (log.gunler[dk]||[]).find(x=>x.id===id);
  if (item) item.done=!item.done;
  savePlanLog(log);
  _renderGunDetay(context, dk);
  if (context==='haftalik') _renderHaftalikTakvim();
  else _renderAylikTakvim();
}

function deleteGunGorev(dk, id, context) {
  const log = getPlanLog();
  log.gunler[dk]=(log.gunler[dk]||[]).filter(x=>x.id!==id);
  savePlanLog(log);
  _renderGunDetay(context, dk);
  if (context==='haftalik') _renderHaftalikTakvim();
  else _renderAylikTakvim();
}





}

function toggleIstatDers(id) {
  const el = document.getElementById(id);
  const ch = document.getElementById(id + '-ch');
  if (!el) return;
  const isOpen = el.style.display !== 'none';
  el.style.display = isOpen ? 'none' : 'block';
  if (ch) ch.style.transform = isOpen ? '' : 'rotate(-180deg)';
}

function applyIstatFiltre(log) {
  return log.filter(d => {
    if (istatBransDers && d.tab !== istatBransDers) return false;
    if (istatFiltreler.yer.length > 0 && !istatFiltreler.yer.includes(d.yer||'ev')) return false;
    if (istatFiltreler.pdf === true && !d.pdf) return false;
    if (istatFiltreler.pdf === false && d.pdf) return false;
    return true;
  });
}

let istatBransDers = null;

function switchIstatBransDers(tab) {
  istatBransDers = istatBransDers === tab ? null : tab;
  // Accordion'u kapatmadan sadece chip stillerini güncelle
  const allTabs = [
    'tyt-turkce','tyt-problem','tyt-mat','tyt-geo','tyt-mat-prob',
    'tyt-fen-den','tyt-fiz','tyt-kim','tyt-bio',
    'tyt-sos-den','tyt-tar','tyt-cog','tyt-fel','tyt-din',
    'ayt-mat','ayt-geo','ayt-fen-den','ayt-fiz','ayt-kim','ayt-bio'
  ];
  allTabs.forEach(t => {
    const chip = document.querySelector(`[onclick="switchIstatBransDers('${t}')"]`);
    if (!chip) return;
    const color = (BS_COLORS[t] || '#8b5cf6');
    if (t === istatBransDers) {
      chip.style.borderColor = color;
      chip.style.background  = color + '22';
      chip.style.color       = color;
    } else {
      chip.style.borderColor = 'var(--border)';
      chip.style.background  = 'transparent';
      chip.style.color       = 'var(--text2)';
    }
  });
  // Sadece istatistik içeriğini (accordion dışını) güncelle
  renderIstatistikIcerik();
}

